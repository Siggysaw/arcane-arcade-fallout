<table>
  <tr>
    {{#each abilities as |ability key|}}
    <td>
        <label for="system.abilities.{{ key }}.value"
               class="resource-label rollable flexlarge align-left specials"
               data-tooltip="1d20 + {{ability.label}} Mod ( {{ability.mod}} ){{#DifferentFrom ../system.penaltyTotal 0}} -  Penalties ( {{../system.penaltyTotal}} ){{/DifferentFrom}} {{#GreaterThan ability.advantage 1}} with advantage {{/GreaterThan}}{{#LesserThan ability.advantage 0}} with disadvantage {{/LesserThan}}"
               data-abilityroll="{{key}}"
               data-roll="d20+{{ ability.mod }}{{#if ability.penalties}}-@penaltyTotal{{/if}}"
               data-advantage="{{ ability.advantage }}"
               data-pipboyselect
               data-label="{{ ability.label }}">{{localize (concat 'FALLOUTZERO.Ability.' key '.long')}}</label>
    </td>
    {{/each}}
  </tr>

  <tr>
    {{#each abilities as |ability key|}}
    <td>
      <div class="flex justify-center gap-5">
        {{#if ../system.editToggle}}<button type="button" class="w-auto no-background" data-statSubtraction
          data-stat="{{ ability.abbr }}" data-type="abilities">
          <i class="fas fa-minus-square "></i>
        </button>{{/if}}
        {{#if ../system.showSpecialBaseMod}}
        <div class="flex gap-3">
          <div class="flex items-center" style="flex-direction: column;">
            <span style="opacity: 0.5; font-size: 0.65rem; line-height: 1;">Base</span>
            <span class="skillvalue">{{ability.base}}</span>
          </div>
          {{#LesserThan ability.modifiers 0}}
          <span style="display: flex; align-items: center;">-</span>
          {{/LesserThan}}
          {{#GreaterThan ability.modifiers 0}}
          <span style="display: flex; align-items: center;">+</span>
          {{/GreaterThan}}
          <div class="flex items-center" style="flex-direction: column;">
            <span style="opacity: 0.5; font-size: 0.65rem; line-height: 1;">Modifier</span>
            <span class="skillvalue">{{ability.modifiers}}</span>
          </div>
        </div>
        {{else}}
        <span class="skillvalue">{{ability.value}}</span>
        {{/if}}
        {{#if ../system.editToggle}}<button type="button" class="w-auto no-background" data-statAddition
          data-stat="{{ ability.abbr }}" data-type="abilities">
          <i class="fas fa-plus-square"></i>
        </button>{{/if}}
      </div>
    </td>
    {{/each}}
  </tr>
  <tr>
    {{#each abilities as |ability key|}}
    <td class="ability-mod">
      <span data-label="{{ ability.label }}">
        {{numberFormat ability.mod decimals=0 sign=true }}
      </span>
    </td>
    {{/each}}
  </tr>
</table>
<div class="flex justify-center" style="margin-top: 4px;">
  <label>
    <input type="checkbox" data-show-special-base-mod {{checked system.showSpecialBaseMod}} />
    Show Base + Modifier
  </label>
</div>